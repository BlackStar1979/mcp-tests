{
  "schema_version": "mcp-tests-runtime-config-spec-v1",
  "spec_mode": "canonical_structured_spec_not_progress_log",
  "scope": "CLI/env/HTTP-route runtime configuration surface derived from active code.",
  "source_refs": [
    "server.js",
    "src/runtime/auth_bootstrap_config_resolver.js",
    "src/runtime/server_cli_args.js",
    "src/runtime/create_server_route_dispatcher.js",
    "src/auth/oauth21_authorization_server.js",
    "src/tool_loader.js"
  ],
  "cli_flags": [
    "--profile",
    "--self-test",
    "--allow-query-token",
    "--trusted-proxy",
    "--auth",
    "--port",
    "--token-file",
    "--oauth-secret-file"
  ],
  "http_routes": [
    "/",
    "/healthz",
    "/docs/<id>",
    "/mcp",
    "/.well-known/oauth-protected-resource",
    "/.well-known/oauth-authorization-server",
    "/register",
    "/authorize",
    "/oauth/operator-login",
    "/token",
    "/revoke"
  ],
  "env_vars": [
    "MCP_TEST_ACCESS_TRUSTED_PROXY",
    "MCP_TEST_ALLOW_PUBLIC_BIND",
    "MCP_TEST_AUDIT_LOG",
    "MCP_TEST_AUDIT_MAX_BYTES",
    "MCP_TEST_AUTH_MODE",
    "MCP_TEST_BEARER_ALLOW_QUERY_TOKEN",
    "MCP_TEST_CODE_SAMPLE_DEFAULT_MAX_CHARS",
    "MCP_TEST_CODE_SAMPLE_HARD_MAX_CHARS",
    "MCP_TEST_CODE_SAMPLE_MAX_FILE_BYTES",
    "MCP_TEST_CODE_SAMPLE_ROOT",
    "MCP_TEST_CORS_ALLOW_ORIGIN",
    "MCP_TEST_ENABLE_CODE_SAMPLE_JS",
    "MCP_TEST_ENABLE_DEV_TOOLS",
    "MCP_TEST_ENABLE_FS_TOOLS",
    "MCP_TEST_ENABLE_NET_TOOLS",
    "MCP_TEST_ENABLE_OBSERVABILITY_TOOLS",
    "MCP_TEST_ENABLE_PLUGIN_CATALOG_TOOLS",
    "MCP_TEST_ENABLE_PLUGIN_EXECUTION_TOOLS",
    "MCP_TEST_ENABLE_PLUGIN_REGISTRY_TOOLS",
    "MCP_TEST_ENABLE_PLUGIN_VISIBILITY_TOOLS",
    "MCP_TEST_ENABLE_RESTART_TRIGGER",
    "MCP_TEST_ENABLE_RUNTIME_STATUS",
    "MCP_TEST_ENABLE_SESSION_TOOLSET_TOOLS",
    "MCP_TEST_FETCH_CAP_CHARS",
    "MCP_TEST_FS_MAX_FILE_BYTES",
    "MCP_TEST_FS_MAX_LIST_ENTRIES",
    "MCP_TEST_FS_MAX_TEXT_CHARS",
    "MCP_TEST_FS_ROOT",
    "MCP_TEST_HEALTH_FULL",
    "MCP_TEST_HOST",
    "MCP_TEST_LOG_DIR",
    "MCP_TEST_MAX_BATCH_ITEMS",
    "MCP_TEST_MEMORY_LOG_DIR",
    "MCP_TEST_NET_ALLOWLIST",
    "MCP_TEST_NET_MAX_BYTES",
    "MCP_TEST_NET_TIMEOUT_MS",
    "MCP_TEST_OAUTH_AS_METADATA_FILE",
    "MCP_TEST_OAUTH_AUDIENCE",
    "MCP_TEST_OAUTH_CLIENTS_FILE",
    "MCP_TEST_OAUTH_HS256_SECRET_FILE",
    "MCP_TEST_OAUTH_INTROSPECTION_FILE",
    "MCP_TEST_OAUTH_ISSUER",
    "MCP_TEST_OAUTH_JWKS_FILE",
    "MCP_TEST_OAUTH_OPERATOR_SECRET",
    "MCP_TEST_OUTPUT_MODE",
    "MCP_TEST_PORT",
    "MCP_TEST_PROFILE",
    "MCP_TEST_PUBLIC_BASE_URL",
    "MCP_TEST_PYTHON_BIN",
    "MCP_TEST_RATE_LIMIT_ENABLED",
    "MCP_TEST_RATE_LIMIT_RESTART_MAX",
    "MCP_TEST_RATE_LIMIT_RESTART_WINDOW_MS",
    "MCP_TEST_RATE_LIMIT_STATE_FILE",
    "MCP_TEST_RATE_LIMIT_TOOL_MAX",
    "MCP_TEST_RATE_LIMIT_TOOL_WINDOW_MS",
    "MCP_TEST_RESTART_EXIT_DELAY_MS",
    "MCP_TEST_RESTART_TRIGGER_FILE",
    "MCP_TEST_STRICT_STREAMABLE_HTTP_ACCEPT",
    "MCP_TEST_TOKEN_FILE"
  ],
  "behavior_refs": {
    "cors": "MCP_TEST_CORS_ALLOW_ORIGIN",
    "health_full": "MCP_TEST_HEALTH_FULL",
    "batch_limit": "MCP_TEST_MAX_BATCH_ITEMS",
    "strict_accept": "MCP_TEST_STRICT_STREAMABLE_HTTP_ACCEPT",
    "public_bind_guard": "MCP_TEST_ALLOW_PUBLIC_BIND",
    "rate_limit": "MCP_TEST_RATE_LIMIT_ENABLED"
  },
  "protocol_versions": [
    "2025-06-18",
    "2025-03-26"
  ],
  "rules": {
    "env_coverage": "all active MCP_TEST_* tokens in src/tools must be listed",
    "route_coverage": "external HTTP routes from dispatcher/oauth21 server must be listed",
    "not_progress_log": true
  },
  "unsupported_cli_flags": [
    "--enable-memory-tools",
    "--memory-tools",
    "--disable-memory-tools",
    "--no-memory-tools"
  ],
  "retired_cli_flags": [],
  "restart_supervisor": {
    "scripts": [
      "scripts/server.sh",
      "scripts/server.ps1",
      "scripts/request-restart.js"
    ],
    "controlled_exit_codes": [
      42,
      43,
      44
    ],
    "trigger_env": {
      "enabled": "MCP_TEST_ENABLE_RESTART_TRIGGER",
      "file": "MCP_TEST_RESTART_TRIGGER_FILE",
      "delay_ms": "MCP_TEST_RESTART_EXIT_DELAY_MS"
    },
    "default_trigger_file": "_control/restart-request.json",
    "surface_change": false,
    "cli_args": [
      "--profile",
      "--auth",
      "--port",
      "--token-file",
      "--oauth-secret-file",
      "--restart-trigger",
      "--trigger-file",
      "--restart-codes",
      "--restart-delay-seconds"
    ],
    "arg_priority": "cli_args_override_supervisor_env_then_defaults",
    "arg_formats": [
      "--key value",
      "--key=value"
    ]
  },
  "rate_limit_quota_runtime": {
    "source_refs": [
      "src/runtime/rate_limit_policy.js",
      "src/runtime/rate_limit_state.js",
      "src/runtime/tools_call_handler.js",
      "src/runtime/restart_controller.js"
    ],
    "tool_call_default": {
      "window_ms": 60000,
      "max": 10000
    },
    "restart_default": {
      "window_ms": 600000,
      "max": 3,
      "state_file": "_control/rate-limit-state.json"
    },
    "denial_events": [
      "tool_call_rate_limited",
      "runtime_restart_rate_limited"
    ]
  }
}
