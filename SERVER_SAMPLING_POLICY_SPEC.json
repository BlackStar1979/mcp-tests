{
  "schema_version": "mcp-tests-sampling-policy-v1",
  "status": "implemented_h7_policy",
  "sampling_role": "server_may_request_client_sampling_only_when_client_declares_sampling_capability",
  "approval_policy": {
    "approval_required_by_default": true,
    "low_risk_auto_approve_allowed": true,
    "approval_receipt_required_for_non_low_risk": true,
    "approval_receipt_param": "approvalReceipt",
    "approval_receipt_status_required": "approved",
    "deny_when_approval_required_but_unavailable": true
  },
  "risk_classification": {
    "low_risk": {
      "max_messages": 1,
      "max_tokens": 128,
      "allowed_content_types": [
        "text"
      ],
      "disallow_system_role": true
    },
    "requires_approval_when": [
      "system role is present",
      "message count exceeds low risk maximum",
      "maxTokens exceeds low risk maximum",
      "non-text content is present",
      "tool-provided hidden instructions are present"
    ]
  },
  "budget_policy": {
    "per_session_sampling_budget_required": true,
    "default_per_session_request_limit": 3,
    "deny_when_budget_exhausted": true
  },
  "prompt_injection_policy": {
    "tool_hidden_instructions_must_not_bypass_approval": true,
    "params_hidden_instruction_keys": [
      "hiddenInstructions",
      "systemOverride",
      "developerOverride"
    ]
  },
  "audit_policy": {
    "audit_receipt_required": true,
    "audit_events": [
      "sampling_request_sent",
      "sampling_request_denied"
    ]
  },
  "guard": "_tests/smoke_stage12_sampling_user_approval_policy.js",
  "spec_mode": "canonical_structured_spec_not_progress_log",
  "scope": "Client sampling policy: capability requirement, approval policy, low-risk classification, budget policy, prompt-injection guard and audit events.",
  "runtime_enforced": "implemented_guarded_policy",
  "connector_visible": false,
  "sessionless_ready_review": {
    "status": "sessionless_ready_reviewed",
    "date": "2026-06-29",
    "source_of_truth": "_workflow/sessionless_inventory.json#target_selection_readiness",
    "workflow_record": "_workflow/operator_decisions/s6_legacy_auth_cleanup_sessionless_ready_review.md",
    "guard": "_tests/smoke_s6_legacy_archive_sessionless_ready_specs.js",
    "current_stable_route": "/mcp",
    "current_stable_route_status": "legacy_compatible_do_not_remove",
    "sessionless_workbench_standard_route": "/mcp/sessionless",
    "sessionless_workbench_env": "MCP_TEST_ENABLE_SESSIONLESS_PROTOTYPE",
    "root_spec_runtime_change": false,
    "connector_visible_surface_changed": false,
    "connector_refresh_required_now": false,
    "runtime_restart_required_now": false,
    "public_3009_start_required_now": false,
    "notes": "Root spec reviewed for sessionless-ready workflow posture; stable connector route remains unchanged and sessionless activation/migration remain separate explicit operator stages."
  }
}
